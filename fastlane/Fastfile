default_platform(:android)

platform :android do

  desc "Build release AAB"
  lane :beta do
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android/",
      properties: {
        "android.injected.signing.store.file" => File.expand_path("../android/upload-key-new.jks"),
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASSWORD"] || "Wezume@2024",
        "android.injected.signing.key.alias" => ENV["KEY_ALIAS"] || "wezume-upload",
        "android.injected.signing.key.password" => ENV["KEY_PASSWORD"] || "Wezume@2024",
      }
    )
    UI.success("✅ AAB built: android/app/build/outputs/bundle/release/app-release.aab")
  end

end
